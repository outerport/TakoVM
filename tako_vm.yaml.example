# Tako VM Configuration
# Copy to tako_vm.yaml and customize as needed.

# ==============================================================================
# QUICK START - Most users only need to change these
# ==============================================================================

production_mode: false    # true = strict mode (no auto-build, versions required)
max_workers: 4            # concurrent execution slots

# ==============================================================================
# EXECUTION LIMITS
# ==============================================================================

default_timeout: 30       # seconds (jobs can override up to max_timeout)
max_timeout: 300          # maximum allowed timeout

max_code_bytes: 102400    # 100KB - max code size per request
max_input_bytes: 1048576  # 1MB - max input data size
max_stdout_bytes: 65536   # 64KB - stdout capture limit
max_stderr_bytes: 65536   # 64KB - stderr capture limit

# ==============================================================================
# CONTAINER SECURITY
# ==============================================================================

docker_image: code-executor:latest
enable_seccomp: true      # syscall filtering (recommended)
enable_userns: true       # run as non-root inside container (recommended)

container_limits:
  pids_limit: 100         # max processes per container
  nofile_soft: 256        # file descriptor soft limit
  nofile_hard: 256        # file descriptor hard limit
  nproc_soft: 50          # process count soft limit
  nproc_hard: 50          # process count hard limit
  fsize: 104857600        # max file size: 100MB
  tmpfs_size: "100m"      # /tmp size

# ==============================================================================
# JOB TYPES
# Pre-configured environments with specific dependencies and limits.
# Each job type becomes a Docker image: tako-vm-{name}:latest
# ==============================================================================

job_types:

  # Basic data processing with pandas/numpy
  - name: data-processing
    requirements:
      - pandas
      - numpy
    memory_limit: "1g"
    cpu_limit: 2.0
    timeout: 60

  # ML inference (no GPU)
  - name: ml-inference
    requirements:
      - numpy
      - scikit-learn
      - joblib
    memory_limit: "2g"
    cpu_limit: 2.0
    timeout: 120

  # API calls with network access
  - name: api-client
    requirements:
      - requests
      - httpx
    memory_limit: "256m"
    timeout: 30
    network_enabled: true           # allows outbound connections
    allowed_hosts:                  # restrict to specific domains
      - "api.openai.com"
      - "api.anthropic.com"
      - "*.amazonaws.com"

# ==============================================================================
# PATHS (usually leave as defaults)
# ==============================================================================

# data_dir: ~/.tako_vm
# database_file: ~/.tako_vm/executions.db

# ==============================================================================
# OTHER SETTINGS
# ==============================================================================

max_queue_size: 100                 # pending jobs before rejecting
max_artifact_bytes: 10485760        # 10MB per output file
max_total_artifacts_bytes: 52428800 # 50MB total output
execution_record_ttl_days: 30       # days to keep execution history
